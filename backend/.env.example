# Copy this file to .env and adjust (never commit .env).
# Django loads backend/.env automatically (python-dotenv).

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database — pick ONE approach
# ---------------------------------------------------------------------------
# (A) Local dev (default): omit DATABASE_URL → SQLite file backend/db.sqlite3
#     Run: python manage.py migrate
#
# (B) PostgreSQL (Docker, RDS, Neon, etc.): set DATABASE_URL (no spaces).
#     Example (RDS with SSL — default ssl when DJANGO_DEBUG=false):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
#
#     Local Postgres without SSL (e.g. Docker on localhost):
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME
# DATABASE_SSL_REQUIRE=false
#
# After changing DATABASE_URL: python manage.py migrate

# Optional: force SSL on/off when using DATABASE_URL (true/false; auto if unset)
# DATABASE_SSL_REQUIRE=true

# Production: CORS — exact origins for your frontend (comma-separated)
# DJANGO_CORS_ORIGINS=https://httpsdxf.github.io,https://httpsdxf.me,http://localhost:3000

# Hire / contact form (optional)
# CONTACT_NOTIFICATION_EMAIL=your-inbox@example.com
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Production: S3 media (optional locally)
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_DEFAULT_REGION=us-east-1
